# Database (PostgreSQL)
# Option A - Local Docker: run "docker compose up -d" then use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/droplink?schema=public"
# Option B - Neon/Supabase: copy connection string from dashboard
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/droplink?schema=public"

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (storage + optional auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
